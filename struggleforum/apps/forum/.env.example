DATABASE_URL="postgresql://struggleforum:struggleforum@localhost:5432/struggleforum?schema=public"
CORS_ALLOWED_ORIGINS="http://localhost:3001"

# Used by `npm run seed -w @struggleforum/forum`.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-this-local-password"

# Used by `npm run test:integration -w @struggleforum/forum`.
# Must point at a database whose name ends in "_test" - the test suite
# refuses to run (and the reset helper refuses to truncate) otherwise,
# so it can never accidentally target your dev database.
TEST_DATABASE_URL="postgresql://struggleforum:struggleforum@localhost:5432/struggleforum_test?schema=public"

